<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | Kithumula Senior School</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="login-body">

  <!-- Login page header -->
  <div class="login-page-header">
    <a href="/" class="login-school-brand">
      <img src="/images/logo.png" alt="KSS Logo" class="login-header-logo">
      <div>
        <div class="login-school-name">KITHUMULA SENIOR SCHOOL</div>
        <div class="login-school-motto">Forward Ever, Backwards Never</div>
      </div>
    </a>
  </div>

  <div class="login-page">
    <div class="login-card">
      <div class="login-logo">
        <div class="login-portal-icon">🔐</div>
        <h2>Admin Portal</h2>
        <p>Sign in with your admin credentials</p>
      </div>
      <% if (flash.error && flash.error.length) { %><div class="flash flash-error"><%= flash.error[0] %></div><% } %>
      <% if (flash.success && flash.success.length) { %><div class="flash flash-success"><%= flash.success[0] %></div><% } %>
      <form action="/admin/login" method="POST">
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" required placeholder="admin@kithumula.sc.ke" autofocus>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn-submit">Sign In to Admin Portal</button>
      </form>
      <div class="login-links">
        <a href="/">← Back to school website</a>
        <a href="/teacher/login">Teacher login →</a>
      </div>
    </div>
  </div>

  <div style="text-align:center;padding:1.25rem;font-size:0.75rem;color:rgba(255,255,255,0.3);">
    &copy; <%= new Date().getFullYear() %> Kithumula Senior School &nbsp;|&nbsp;
    Powered by <a href="https://jaytechnologies.vercel.app/" target="_blank" rel="noopener" style="color:var(--gold);text-decoration:none;">JayTechnologies</a>
  </div>

</body></html>
