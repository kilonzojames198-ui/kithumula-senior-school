<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Classes | KSS Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .two-col { display:grid; grid-template-columns:1fr 1.6fr; gap:2rem; align-items:start; }
    @media(max-width:768px){ .two-col { grid-template-columns:1fr; } }
  </style>
</head>
<body class="admin-body">
<%- include('nav', { activePage: 'classes' }) %>
<div class="admin-layout">
  <div class="admin-page-header">
    <h1>Classes</h1>
    <p>Manage school classes and assign class teachers.</p>
  </div>
  <% if (flash.success && flash.success.length) { %><div class="flash flash-success"><%= flash.success[0] %></div><% } %>
  <% if (flash.error   && flash.error.length)   { %><div class="flash flash-error"><%= flash.error[0] %></div><% } %>

  <div class="two-col">
    <div class="admin-card">
      <div class="admin-card-header"><h2>Create New Class</h2></div>
      <form action="/admin/classes" method="POST" class="admin-form">
        <div class="form-group">
          <label>Class Name *</label>
          <input type="text" name="name" required placeholder="e.g. Grade 10A">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Grade *</label>
            <select name="grade" required>
              <option value="">Select grade</option>
              <option value="Grade 10">Grade 10</option>
              <option value="Grade 11">Grade 11</option>
              <option value="Grade 12">Grade 12</option>
            </select>
          </div>
          <div class="form-group">
            <label>Stream *</label>
            <input type="text" name="stream" required placeholder="e.g. A, B">
          </div>
        </div>
        <div class="form-group">
          <label>Class Teacher</label>
          <select name="class_teacher_id">
            <option value="">— None —</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t.id %>"><%= t.name %> (<%= t.staff_number %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Academic Year</label>
          <input type="text" name="academic_year" value="2026">
        </div>
        <button type="submit" class="btn-primary">Create Class</button>
      </form>
    </div>

    <div class="admin-card">
      <div class="admin-card-header"><h2>All Classes (<%= classes.length %>)</h2></div>
      <% if (!classes.length) { %>
        <p style="padding:2rem;text-align:center;color:#94a3b8;">No classes yet.</p>
      <% } else { %>
      <div style="overflow-x:auto;">
        <table class="admin-table" style="min-width:420px;">
          <thead><tr><th>Class</th><th>Grade</th><th>Students</th><th>Class Teacher</th><th>Actions</th></tr></thead>
          <tbody>
            <% classes.forEach(c => { %>
            <tr>
              <td><strong><%= c.name %></strong></td>
              <td><span class="badge badge-blue"><%= c.grade %></span></td>
              <td><%= c.student_count %></td>
              <td style="color:var(--text-muted);font-size:0.85rem;"><%= c.teacher_name || '—' %></td>
              <td>
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                  <a href="/admin/students?class_id=<%= c.id %>" class="btn-secondary btn-sm">Students</a>
                  <form action="/admin/classes/<%= c.id %>/delete" method="POST" onsubmit="return confirm('Delete <%= c.name %>?')">
                    <button type="submit" class="btn-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/portal-footer') %>
</body></html>
