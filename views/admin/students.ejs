<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Students | KSS Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .photo-upload-area {
      border: 2px dashed var(--border); border-radius: 8px; padding: 1.25rem;
      text-align: center; cursor: pointer; transition: all 0.2s; background: var(--light);
      position: relative;
    }
    .photo-upload-area:hover, .photo-upload-area.drag-over { border-color: var(--navy-mid); background: #e8edf8; }
    .photo-upload-area input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
    .photo-preview { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 2px solid var(--gold); margin: 0 auto 0.5rem; display: none; }
    .photo-placeholder-icon { font-size: 2.5rem; margin-bottom: 0.25rem; }
    .student-avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border); }
    .student-avatar-placeholder { width: 36px; height: 36px; border-radius: 50%; background: var(--light); display: flex; align-items: center; justify-content: center; font-size: 1rem; border: 1px solid var(--border); }
    .enrol-form-card { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .form-section-title { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); padding: 0.75rem 1.5rem; background: var(--light); border-bottom: 1px solid var(--border); }
    .form-inner { padding: 1.5rem; }
  </style>
</head>
<body class="admin-body">
<%- include('nav', { activePage: 'students' }) %>
<div class="admin-layout">
  <div class="admin-page-header">
    <h1>Students</h1>
    <p>Enrol and manage student records. Total active: <strong><%= students.length %></strong></p>
  </div>
  <% if (flash.success && flash.success.length) { %><div class="flash flash-success"><%= flash.success[0] %></div><% } %>
  <% if (flash.error && flash.error.length) { %><div class="flash flash-error"><%= flash.error[0] %></div><% } %>

  <!-- Class filter tabs -->
  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
    <a href="/admin/students" style="padding:0.4rem 1rem;border-radius:20px;font-size:0.8rem;font-weight:600;border:1px solid var(--border);background:<%= !classId?'var(--navy)':'white' %>;color:<%= !classId?'white':'var(--text-muted)' %>;">All Classes</a>
    <% classes.forEach(c => { %>
      <a href="/admin/students?class_id=<%= c.id %>" style="padding:0.4rem 1rem;border-radius:20px;font-size:0.8rem;font-weight:600;border:1px solid var(--border);background:<%= classId==c.id?'var(--navy)':'white' %>;color:<%= classId==c.id?'white':'var(--text-muted)' %>;"><%= c.name %></a>
    <% }) %>
  </div>

  <div style="display:grid;grid-template-columns:340px 1fr;gap:2rem;align-items:start;">

    <!-- ─ ENROL FORM ─ -->
    <div class="enrol-form-card">
      <div style="background:var(--navy);padding:1.25rem 1.5rem;">
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.2rem;color:white;margin:0;">Enrol New Student</h2>
        <p style="font-size:0.8rem;color:rgba(255,255,255,0.55);margin-top:3px;">Fill in the student's details below</p>
      </div>

      <form action="/admin/students" method="POST" enctype="multipart/form-data">
        <!-- Photo upload -->
        <div style="padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);">
          <label style="font-size:0.8rem;font-weight:600;color:var(--navy);display:block;margin-bottom:0.6rem;">Passport Photo <span style="color:#94a3b8;font-weight:400;">(recommended)</span></label>
          <div class="photo-upload-area" id="photoArea">
            <input type="file" name="photo" accept="image/*" id="photoInput" onchange="previewPhoto(this)">
            <div id="photoPlaceholder">
              <div class="photo-placeholder-icon">📷</div>
              <div style="font-size:0.82rem;font-weight:600;color:var(--navy);">Click or drag photo here</div>
              <div style="font-size:0.75rem;color:#94a3b8;margin-top:2px;">JPG, PNG • max 5MB</div>
            </div>
            <img id="photoPreview" class="photo-preview" src="" alt="Preview">
          </div>
        </div>

        <div class="form-inner" style="display:flex;flex-direction:column;gap:1rem;">
          <div class="form-group" style="margin:0;">
            <label>Full Name *</label>
            <input type="text" name="name" required placeholder="Student's full name">
          </div>
          <div style="background:#f0fdf4;border:1px solid #a7f3d0;border-radius:6px;padding:0.65rem 1rem;font-size:0.8rem;color:#065f46;display:flex;align-items:center;gap:8px;">
            <span>🎫</span> <span>Admission number will be <strong>automatically generated</strong> (e.g. KSS2026001)</span>
          </div>
          <div class="form-group" style="margin:0;">
            <label>Class *</label>
            <select name="class_id" required>
              <option value="">Select class</option>
              <% classes.forEach(c => { %><option value="<%= c.id %>" <%= classId==c.id?'selected':'' %>><%= c.name %></option><% }) %>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group" style="margin:0;">
              <label>Gender</label>
              <select name="gender">
                <option value="">—</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
              </select>
            </div>
            <div class="form-group" style="margin:0;">
              <label>Date of Birth</label>
              <input type="date" name="dob">
            </div>
          </div>
          <div style="border-top:1px solid var(--border);padding-top:1rem;">
            <div style="font-size:0.68rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.75rem;">Parent / Guardian</div>
            <div class="form-group" style="margin:0 0 1rem;">
              <label>Parent Name</label>
              <input type="text" name="parent_name" placeholder="Full name">
            </div>
            <div class="form-group" style="margin:0;">
              <label>Parent Phone</label>
              <input type="tel" name="parent_phone" placeholder="07XX XXX XXX">
            </div>
          </div>
          <button type="submit" class="btn-submit" style="margin-top:0.25rem;">✓ Enrol Student</button>
        </div>
      </form>
    </div>

    <!-- ─ STUDENTS TABLE ─ -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2>Students (<%= students.length %>)</h2>
        <input type="text" id="searchInput" placeholder="Search name or adm no…" onkeyup="filterTable()" style="padding:0.4rem 0.85rem;border:1px solid var(--border);border-radius:6px;font-size:0.82rem;font-family:inherit;width:200px;">
      </div>
      <% if (!students.length) { %>
        <p style="padding:2rem;text-align:center;color:#94a3b8;">No students yet.<% if(classId) { %> <a href="/admin/students" style="color:var(--red);">View all classes</a><% } %></p>
      <% } else { %>
      <table class="admin-table" id="studentsTable">
        <thead>
          <tr><th>Photo</th><th>Name</th><th>Adm No.</th><th>Class</th><th>Gender</th><th>Parent</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% students.forEach((s, i) => { %>
          <tr>
            <td>
              <% if (s.photo) { %>
                <img src="<%= s.photo %>" alt="<%= s.name %>" class="student-avatar">
              <% } else { %>
                <div class="student-avatar-placeholder">👤</div>
              <% } %>
            </td>
            <td><strong><%= s.name %></strong></td>
            <td style="font-size:0.82rem;color:var(--text-muted);font-family:monospace;"><%= s.adm_number %></td>
            <td><span class="badge badge-blue"><%= s.class_name %></span></td>
            <td style="font-size:0.82rem;"><%= s.gender || '—' %></td>
            <td style="font-size:0.82rem;color:var(--text-muted);"><%= s.parent_phone || '—' %></td>
            <td>
              <form action="/admin/students/<%= s.id %>/delete" method="POST" onsubmit="return confirm('Remove <%= s.name %>?')">
                <button type="submit" class="btn-danger btn-sm">Remove</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>
<script>
function previewPhoto(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const preview = document.getElementById('photoPreview');
    const placeholder = document.getElementById('photoPlaceholder');
    preview.src = e.target.result;
    preview.style.display = 'block';
    placeholder.style.display = 'none';
  };
  reader.readAsDataURL(file);
}
function filterTable() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  document.querySelectorAll('#studentsTable tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
// Drag and drop
const area = document.getElementById('photoArea');
area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('drag-over'); });
area.addEventListener('dragleave', () => area.classList.remove('drag-over'));
area.addEventListener('drop', e => {
  e.preventDefault(); area.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) {
    document.getElementById('photoInput').files = e.dataTransfer.files;
    previewPhoto(document.getElementById('photoInput'));
  }
});
</script>
<%- include('../partials/portal-footer') %>
</body></html>
