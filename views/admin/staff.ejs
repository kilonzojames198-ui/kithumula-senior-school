<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff | KSS Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .staff-cards-mobile { display:none; }
    .staff-card-m { background:white; border:1px solid var(--border); border-radius:10px; padding:1.25rem; margin-bottom:0.75rem; display:flex; gap:1rem; align-items:flex-start; }
    .staff-card-m .info { flex:1; min-width:0; }
    .staff-card-m .actions { display:flex; gap:0.5rem; flex-shrink:0; flex-direction:column; }
    @media(max-width:640px){
      .staff-table-wrap { display:none; }
      .staff-cards-mobile { display:block; }
    }
  </style>
</head>
<body class="admin-body">
<%- include('nav', { activePage: 'staff' }) %>
<div class="admin-layout">
  <div class="admin-page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
    <div>
      <h1>Staff Management</h1>
      <p>Add, edit, or remove staff members shown on the public directory.</p>
    </div>
    <a href="/admin/staff/new" class="btn-primary">+ Add Staff Member</a>
  </div>
  <% if (flash.success && flash.success.length) { %><div class="flash flash-success"><%= flash.success[0] %></div><% } %>
  <% if (flash.error   && flash.error.length)   { %><div class="flash flash-error"><%= flash.error[0] %></div><% } %>

  <!-- Desktop table -->
  <div class="admin-card staff-table-wrap">
    <div class="admin-card-header"><h2>All Staff (<%= staff.length %>)</h2></div>
    <div style="overflow-x:auto;">
      <table class="admin-table" style="min-width:600px;">
        <thead><tr><th>Photo</th><th>Name</th><th>Staff #</th><th>Role</th><th>Dept</th><th>Teacher?</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (!staff.length) { %><tr><td colspan="8" style="text-align:center;color:#94a3b8;padding:2rem;">No staff yet. <a href="/admin/staff/new" style="color:var(--red);">Add first one.</a></td></tr><% } %>
          <% staff.forEach(s => { %>
          <tr>
            <td>
              <% if (s.photo) { %><img src="<%= s.photo %>" style="width:36px;height:36px;border-radius:50%;object-fit:cover;">
              <% } else { %><div style="width:36px;height:36px;border-radius:50%;background:var(--light);display:flex;align-items:center;justify-content:center;">👤</div><% } %>
            </td>
            <td><strong><%= s.name %></strong></td>
            <td style="font-family:monospace;font-size:0.82rem;color:#94a3b8;"><%= s.staff_number %></td>
            <td><%= s.role %></td>
            <td><span class="badge badge-blue"><%= s.department %></span></td>
            <td style="text-align:center;"><%= s.is_teacher?'✅':'—' %></td>
            <td><span class="badge <%= s.is_active?'badge-green':'badge-gray' %>"><%= s.is_active?'Active':'Inactive' %></span></td>
            <td>
              <div style="display:flex;gap:0.4rem;">
                <a href="/admin/staff/<%= s.id %>/edit" class="btn-secondary btn-sm">Edit</a>
                <form action="/admin/staff/<%= s.id %>" method="POST" onsubmit="return confirm('Remove <%= s.name %>?')">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="btn-danger btn-sm">Remove</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile cards -->
  <div class="staff-cards-mobile">
    <% if (!staff.length) { %>
      <p style="text-align:center;color:#94a3b8;padding:2rem;">No staff yet. <a href="/admin/staff/new" style="color:var(--red);">Add first one.</a></p>
    <% } %>
    <% staff.forEach(s => { %>
    <div class="staff-card-m">
      <% if (s.photo) { %>
        <img src="<%= s.photo %>" style="width:52px;height:52px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--border);">
      <% } else { %>
        <div style="width:52px;height:52px;border-radius:50%;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">👤</div>
      <% } %>
      <div class="info">
        <strong style="color:var(--navy);"><%= s.name %></strong>
        <div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px;"><%= s.role %> · <%= s.department %></div>
        <div style="font-size:0.75rem;color:#94a3b8;margin-top:2px;">Staff#: <%= s.staff_number %></div>
        <div style="margin-top:0.5rem;display:flex;gap:0.4rem;flex-wrap:wrap;">
          <span class="badge <%= s.is_active?'badge-green':'badge-gray' %>"><%= s.is_active?'Active':'Inactive' %></span>
          <% if (s.is_teacher) { %><span class="badge badge-blue">Teacher</span><% } %>
        </div>
      </div>
      <div class="actions">
        <a href="/admin/staff/<%= s.id %>/edit" class="btn-secondary btn-sm">Edit</a>
        <form action="/admin/staff/<%= s.id %>" method="POST" onsubmit="return confirm('Remove?')">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn-danger btn-sm">Remove</button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<%- include('../partials/portal-footer') %>
</body></html>
