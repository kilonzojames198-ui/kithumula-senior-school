<%- include('partials/head', { title: 'My Results' }) %>
<%- include('partials/nav') %>

<style>
  .results-page { padding: 4rem 0 6rem; background: var(--off-white); min-height: 70vh; }
  .report-wrapper { max-width: 820px; margin: 0 auto; }

  /* Student ID card */
  .student-id-card {
    background: var(--navy);
    border-radius: 12px;
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .student-id-card .avatar {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; flex-shrink: 0;
  }
  .student-id-info h2 { font-family: 'DM Serif Display', serif; font-size: 1.5rem; color: white; }
  .student-id-info p  { font-size: 0.85rem; color: rgba(255,255,255,0.55); margin-top: 3px; }
  .student-meta { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .meta-item { text-align: center; }
  .meta-item .val { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: white; line-height: 1; }
  .meta-item .lbl { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-top: 4px; }

  /* Grade summary strip */
  .grade-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .grade-strip-item {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    text-align: center;
  }
  .grade-strip-item .g-val { font-family: 'DM Serif Display', serif; font-size: 1.8rem; line-height: 1; }
  .grade-strip-item .g-lbl { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-top: 5px; }

  /* Marks table */
  .marks-card { background: white; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
  .marks-card-header { background: var(--navy); padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; }
  .marks-card-header h3 { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: white; }
  .marks-table { width: 100%; border-collapse: collapse; }
  .marks-table th { background: #f8fafc; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); padding: 0.75rem 1.25rem; text-align: left; border-bottom: 1px solid var(--border); }
  .marks-table th.center { text-align: center; }
  .marks-table td { padding: 0.9rem 1.25rem; font-size: 0.9rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
  .marks-table td.center { text-align: center; }
  .marks-table tr:last-child td { border-bottom: none; }
  .marks-table tr:hover td { background: #fafbfc; }
  .marks-table .subject-name { font-weight: 600; color: var(--navy); }
  .marks-table .subject-type { font-size: 0.72rem; color: #94a3b8; }

  .grade-pill {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 26px;
    border-radius: 5px;
    font-size: 0.78rem; font-weight: 700;
    margin: auto;
  }
  .gp-EE { background: #d1fae5; color: #065f46; }
  .gp-ME { background: #dbeafe; color: #1e40af; }
  .gp-AE { background: #fef9c3; color: #92400e; }
  .gp-BE { background: #fee2e2; color: #991b1b; }

  .total-bar {
    height: 6px; border-radius: 3px;
    background: #e2e8f0; overflow: hidden; margin-top: 4px;
  }
  .total-bar-fill { height: 100%; border-radius: 3px; }

  /* Download button */
  .download-section {
    background: white; border: 1px solid var(--border);
    border-radius: 10px; padding: 1.75rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1.5rem;
  }
  .download-section h3 { font-family: 'DM Serif Display', serif; font-size: 1.3rem; color: var(--navy); margin-bottom: 3px; }
  .download-section p { font-size: 0.85rem; color: var(--text-muted); }
  .btn-download {
    display: flex; align-items: center; gap: 10px;
    background: var(--red); color: white;
    padding: 0.85rem 1.75rem; border-radius: 8px;
    font-weight: 600; font-size: 0.9rem; white-space: nowrap;
    transition: background 0.2s;
  }
  .btn-download:hover { background: var(--red-dark); color: white; }
  .btn-download .dl-icon { font-size: 1.2rem; }

  /* No marks state */
  .no-marks { text-align: center; padding: 4rem 2rem; color: #94a3b8; }
  .no-marks .icon { font-size: 3rem; margin-bottom: 1rem; }

  /* Grade key */
  .grade-key {
    background: var(--light); border-radius: 8px; padding: 1rem 1.5rem;
    display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center;
    font-size: 0.8rem; color: var(--text-muted);
  }
  .grade-key strong { color: var(--navy); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 4px; }

  @media (max-width: 600px) {
    .grade-strip { grid-template-columns: repeat(2, 1fr); }
    .student-id-card { flex-direction: column; align-items: flex-start; }
    .student-meta { gap: 1rem; }
    .results-page { padding: 2rem 0 4rem; }
    .marks-table th, .marks-table td { padding: 0.55rem 0.5rem; font-size: 0.78rem; }
    .marks-card { overflow-x: auto; }
    .marks-table { min-width: 420px; }
    .download-section { flex-direction: column; align-items: stretch; padding: 1.25rem; }
    .download-section > div:last-child { display: flex; gap: 0.75rem; }
    .btn-download { flex: 1; justify-content: center; }
    .grade-key { gap: 0.75rem; }
    .student-meta .meta-item .val { font-size: 1.3rem; }
    #pdf-viewer iframe { height: 60vh; }
  }
  @media (max-width: 400px) {
    .grade-strip { grid-template-columns: 1fr 1fr; }
    .student-id-card { padding: 1.25rem; }
    .download-section > div:last-child { flex-direction: column; }
    .btn-download { width: 100%; }
    .marks-card-header { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
  }
</style>

<!-- Breadcrumb -->
<div style="background:var(--navy);padding:1rem 0;">
  <div class="container" style="display:flex;align-items:center;gap:8px;font-size:0.8rem;color:rgba(255,255,255,0.5);">
    <a href="/" style="color:rgba(255,255,255,0.5);">Home</a>
    <span>›</span>
    <a href="/#results-lookup" style="color:rgba(255,255,255,0.5);">Results Lookup</a>
    <span>›</span>
    <span style="color:white;"><%= student.name %></span>
  </div>
</div>

<section class="results-page">
  <div class="container report-wrapper">

    <!-- Student ID card -->
    <div class="student-id-card">
      <div style="display:flex;align-items:center;gap:1.25rem;flex:1;">
        <div class="avatar">👤</div>
        <div class="student-id-info">
          <h2><%= student.name %></h2>
          <p>Adm: <%= student.adm_number %> &nbsp;·&nbsp; <%= student.class_name %> &nbsp;·&nbsp; <%= student.academic_year || '2026' %></p>
        </div>
      </div>
      <div class="student-meta">
        <div class="meta-item">
          <div class="val"><%= rank %><span style="font-size:0.9rem;opacity:0.5;">/<%= classSize %></span></div>
          <div class="lbl">Class Rank</div>
        </div>
        <div class="meta-item">
          <div class="val" style="color:var(--gold);"><%= result.overallGrade || '—' %></div>
          <div class="lbl">Overall Grade</div>
        </div>
        <div class="meta-item">
          <div class="val"><%= result.meanPoints || '—' %></div>
          <div class="lbl">Mean Points</div>
        </div>
      </div>
    </div>

    <% if (!hasMarks) { %>
    <div class="no-marks">
      <div class="icon">📋</div>
      <p style="font-size:1rem;font-weight:600;color:var(--navy);margin-bottom:0.5rem;">Results Not Yet Available</p>
      <p>Marks for your class have not been entered yet. Please check back later or contact your class teacher.</p>
      <a href="/" style="display:inline-block;margin-top:1.5rem;background:var(--navy);color:white;padding:0.7rem 1.75rem;border-radius:6px;font-weight:600;font-size:0.88rem;">← Back to Home</a>
    </div>
    <% } else { %>

    <!-- Summary strip -->
    <div class="grade-strip">
      <div class="grade-strip-item">
        <div class="g-val" style="color:var(--navy);"><%= result.subjectCount %></div>
        <div class="g-lbl">Subjects Assessed</div>
      </div>
      <div class="grade-strip-item">
        <div class="g-val" style="color:var(--navy);"><%= result.totalPoints %></div>
        <div class="g-lbl">Total Points</div>
      </div>
      <div class="grade-strip-item">
        <div class="g-val" style="color:var(--navy);"><%= result.meanPoints %></div>
        <div class="g-lbl">Mean Points</div>
      </div>
      <div class="grade-strip-item">
        <% const gc = result.overallGrade;
           const gcColor = gc==='EE'?'#065f46':gc==='ME'?'#1e40af':gc==='AE'?'#92400e':'#991b1b';
           const gcBg = gc==='EE'?'#d1fae5':gc==='ME'?'#dbeafe':gc==='AE'?'#fef9c3':'#fee2e2';
        %>
        <div class="g-val" style="color:<%= gcColor %>;"><%= gc %></div>
        <div class="g-lbl" style="color:<%= gcColor %>;">Overall Grade</div>
      </div>
    </div>

    <!-- Marks table -->
    <div class="marks-card">
      <div class="marks-card-header">
        <h3>Subject Results — Term 1</h3>
        <span style="font-size:0.75rem;color:rgba(255,255,255,0.45);">Weighted: CAT1 30% + CAT2 30% + End Term 40%</span>
      </div>
      <table class="marks-table">
        <thead>
          <tr>
            <th>Subject</th>
            <% examTypes.forEach(et => { %><th class="center"><%= et.name %><br><span style="font-weight:400;font-size:0.65rem;">/<%= et.weight %></span></th><% }) %>
            <th class="center">Total %</th>
            <th class="center">Grade</th>
          </tr>
        </thead>
        <tbody>
          <% result.results.forEach(r => { %>
          <tr>
            <td>
              <div class="subject-name"><%= r.subject.name %></div>
              <div class="subject-type"><%= r.subject.is_core ? 'Core Subject' : (r.subject.department || 'Pathway') %></div>
            </td>
            <% examTypes.forEach(et => {
              const entry = r.breakdown ? r.breakdown.find(b => b.exam_type_id === et.id) : null;
            %>
            <td class="center" style="font-size:0.88rem;">
              <% if (entry) { %>
                <strong style="color:var(--navy);"><%= entry.marks_obtained %></strong>
              <% } else { %>
                <span style="color:#cbd5e1;">—</span>
              <% } %>
            </td>
            <% }) %>
            <td class="center">
              <% if (r.total !== null) { %>
                <div style="font-weight:700;color:var(--navy);font-size:0.95rem;"><%= r.total.toFixed(1) %>%</div>
                <div class="total-bar">
                  <div class="total-bar-fill" style="width:<%= r.total %>%;background:<%= r.grade==='EE'?'#059669':r.grade==='ME'?'#2563eb':r.grade==='AE'?'#d97706':'#dc2626' %>;"></div>
                </div>
              <% } else { %><span style="color:#cbd5e1;">—</span><% } %>
            </td>
            <td class="center">
              <% if (r.grade) { %>
                <span class="grade-pill gp-<%= r.grade %>"><%= r.grade %></span>
              <% } else { %><span style="color:#cbd5e1;">—</span><% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
        <!-- Summary row -->
        <tfoot>
          <tr style="background:var(--navy);">
            <td style="padding:0.85rem 1.25rem;font-size:0.82rem;font-weight:700;color:white;letter-spacing:0.05em;">OVERALL SUMMARY</td>
            <% examTypes.forEach(() => { %><td></td><% }) %>
            <td class="center" style="padding:0.85rem 1.25rem;">
              <span style="font-family:'DM Serif Display',serif;font-size:1.1rem;color:white;font-weight:700;"><%= result.meanPoints %> pts</span>
            </td>
            <td class="center" style="padding:0.85rem 1.25rem;">
              <span class="grade-pill gp-<%= result.overallGrade %>" style="width:auto;padding:4px 10px;font-size:0.82rem;"><%= result.overallGrade %></span>
            </td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Grade key -->
    <div class="grade-key" style="margin-bottom:1.5rem;">
      <strong>Grading Scale</strong>
      <span><span style="background:#d1fae5;color:#065f46;padding:2px 7px;border-radius:3px;font-weight:700;font-size:0.75rem;">EE</span> Exceeds Expectation (80–100%)</span>
      <span><span style="background:#dbeafe;color:#1e40af;padding:2px 7px;border-radius:3px;font-weight:700;font-size:0.75rem;">ME</span> Meets Expectation (65–79%)</span>
      <span><span style="background:#fef9c3;color:#92400e;padding:2px 7px;border-radius:3px;font-weight:700;font-size:0.75rem;">AE</span> Approaches Expectation (50–64%)</span>
      <span><span style="background:#fee2e2;color:#991b1b;padding:2px 7px;border-radius:3px;font-weight:700;font-size:0.75rem;">BE</span> Below Expectation (&lt;50%)</span>
    </div>

    <!-- View / Download section -->
    <div class="download-section">
      <div>
        <h3>Your Official Report Form</h3>
        <p>View online in your browser or download as a print-ready PDF.</p>
      </div>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        <a href="#pdf-viewer" onclick="openPdfViewer()" class="btn-download" style="background:var(--navy);">
          <span class="dl-icon">👁</span> View PDF
        </a>
        <a href="/results/student/<%= student.id %>/pdf" class="btn-download">
          <span class="dl-icon">📥</span> Download PDF
        </a>
      </div>
    </div>

    <!-- Inline PDF Viewer -->
    <div id="pdf-viewer" style="display:none;margin-bottom:1.5rem;">
      <div style="background:var(--navy);border-radius:10px 10px 0 0;padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;">
        <span style="font-size:0.85rem;font-weight:600;color:white;">📄 Report Form — <%= student.name %></span>
        <div style="display:flex;gap:0.75rem;align-items:center;">
          <a href="/results/student/<%= student.id %>/pdf" style="font-size:0.78rem;color:rgba(255,255,255,0.65);text-decoration:underline;">Download</a>
          <button onclick="closePdfViewer()" style="background:rgba(255,255,255,0.15);border:none;color:white;width:26px;height:26px;border-radius:50%;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;">✕</button>
        </div>
      </div>
      <iframe id="pdfFrame" src="" style="width:100%;height:680px;border:none;border-radius:0 0 10px 10px;background:#525659;" title="Report Form"></iframe>
    </div>

    <!-- Back link -->
    <div style="text-align:center;">
      <a href="/#results-lookup" style="font-size:0.85rem;color:var(--text-muted);">← Look up a different student</a>
      &nbsp;&nbsp;|&nbsp;&nbsp;
      <a href="/" style="font-size:0.85rem;color:var(--text-muted);">Back to Home</a>
    </div>

    <script>
    function openPdfViewer() {
      const viewer = document.getElementById('pdf-viewer');
      const frame  = document.getElementById('pdfFrame');
      viewer.style.display = 'block';
      if (!frame.src || frame.src === window.location.href) {
        frame.src = '/results/student/<%= student.id %>/view';
      }
      viewer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    function closePdfViewer() {
      document.getElementById('pdf-viewer').style.display = 'none';
    }
    </script>

    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
