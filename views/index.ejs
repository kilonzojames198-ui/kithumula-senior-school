<%- include('partials/head', { title: 'Home' }) %>
<style>
  @media(max-width:640px){
    .enrol-grid { grid-template-columns:1fr !important; }
    .form-card { padding:1.5rem 1.1rem; }
    .form-row { grid-template-columns:1fr !important; }
    .cbc-advantage { grid-template-columns:1fr !important; padding:1.5rem; }
    .lookup-form-card { padding:1.5rem 1.1rem; }
    .portal-card { padding:1.5rem; }
    .portals-grid { grid-template-columns:1fr !important; }
    .values-grid { grid-template-columns:1fr !important; }
    .pathways-grid { grid-template-columns:1fr !important; }
    .stats-inner { grid-template-columns:repeat(2,1fr); }
    .stat { padding:1.25rem 0.75rem; }
    .stat-num { font-size:1.6rem; }
    .hero-eyebrow { font-size:0.62rem; }
    .competencies { grid-template-columns:1fr !important; }
    .ann-grid { grid-template-columns:1fr !important; }
    .about-grid { grid-template-columns:1fr !important; }
  }
</style>
<%- include('partials/nav') %>

<!-- HERO -->
<section class="hero">
  <div class="slide active"><img src="/images/slide1.png" alt="Slide 1"></div>
  <div class="slide"><img src="/images/slide2.png" alt="Slide 2"></div>
  <div class="slide"><img src="/images/slide3.png" alt="Slide 3"></div>
  <div class="slide"><img src="/images/slide4.png" alt="Slide 4"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">Matinyani · Kitui County · CBC Senior School</div>
    <h1 class="slide-title" id="slide-title">Excellence in Education</h1>
    <p class="slide-subtitle" id="slide-subtitle">Empowering the next generation in Matinyani through high-quality CBC learning.</p>
    <a href="#enrol" class="btn-hero" id="slide-cta">Enrol for 2026</a>
  </div>
  <div class="slider-dots">
    <div class="dot active" onclick="setSlide(0)"></div>
    <div class="dot" onclick="setSlide(1)"></div>
    <div class="dot" onclick="setSlide(2)"></div>
    <div class="dot" onclick="setSlide(3)"></div>
  </div>
</section>

<!-- STATS -->
<div class="stats-strip">
  <div class="stats-inner">
    <div class="stat"><div class="stat-num">6+</div><div class="stat-label">Partner Schools</div></div>
    <div class="stat"><div class="stat-num">G10–12</div><div class="stat-label">Grades Offered</div></div>
    <div class="stat"><div class="stat-num">CBC</div><div class="stat-label">Curriculum</div></div>
    <div class="stat"><div class="stat-num">Day</div><div class="stat-label">School Type</div></div>
  </div>
</div>

<% if (announcements && announcements.length > 0) { %>
<!-- ANNOUNCEMENTS -->
<section class="announcements-strip">
  <div class="container">
    <div class="section-tag">Latest News</div>
    <h2 class="section-heading" style="margin-bottom:0.5rem;">Announcements</h2>
    <div class="ann-grid">
      <% announcements.forEach(ann => { %>
      <div class="ann-card">
        <span class="ann-badge <%= ann.category %>"><%= ann.category %></span>
        <h4><%= ann.title %></h4>
        <p><%= ann.body.length > 120 ? ann.body.substring(0,120) + '…' : ann.body %></p>
        <div class="ann-date"><%= new Date(ann.created_at).toLocaleDateString('en-KE', { year:'numeric', month:'long', day:'numeric' }) %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <div>
        <div class="section-tag">Our Story</div>
        <h2 class="section-heading">A School That Has Grown With Its Community</h2>
        <p class="about-lead">Originally established as <strong>Kithumula Secondary School</strong>, we have evolved alongside Kenya's education reforms into <strong>Kithumula Senior School</strong> — fully embracing the CBC framework for Grades 10 through 12.</p>
        <p class="about-body">Located in Matinyani Sub-County, Kitui County in Eastern Kenya, the school serves the surrounding community, drawing students from various local institutions:</p>
        <div class="partner-schools">
          <strong>Partner Primary Schools</strong>
          <p>Kithumula Primary, ACK Ngomango Primary, Kaluni Primary, Kitamwiki Primary, Ndiuni Primary, and beyond.</p>
        </div>
        <p class="about-body">We remain committed to providing accessible, high-quality day schooling without the financial burden of boarding fees — ensuring every child in our community can access senior school education.</p>
      </div>
      <div>
        <div class="vm-card">
          <div class="vm-card-tag">Our Vision</div>
          <h3>Outstanding in Academic Excellence</h3>
          <p>To be an outstanding school in academic excellence, positively transforming students' lives for a future full of hope.</p>
        </div>
        <div class="vm-card">
          <div class="vm-card-tag">Our Mission</div>
          <h3>Resources &amp; Opportunity</h3>
          <p>To make use of available resources and opportunities towards producing academically and ethically fit citizens for social and economic development.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="values">
  <div class="container">
    <div class="section-tag">What We Stand For</div>
    <h2 class="section-heading">Our Core Commitments</h2>
    <div class="values-grid">
      <div class="value-card">
        <div class="value-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1a3a6b" stroke-width="1.8" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h4>Academic Excellence</h4>
        <p>We hold every learner to high standards through rigorous CBC-aligned instruction, preparing students for tertiary education and lifelong learning.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1a3a6b" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </div>
        <h4>Community Rooted</h4>
        <p>Born from and built alongside local families, our school exists to serve and uplift the Matinyani community across generations.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1a3a6b" stroke-width="1.8" stroke-linecap="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
        </div>
        <h4>Accessible Education</h4>
        <p>No child should miss senior school because of cost. As a day school, we eliminate boarding fees and keep quality education within reach.</p>
      </div>
    </div>
  </div>
</section>

<!-- PATHWAYS -->
<section class="pathways" id="pathways">
  <div class="container">
    <div class="section-tag">Academics</div>
    <h2 class="section-heading">Academics &amp; Curriculum</h2>
    <p style="color:var(--text-muted);font-size:1rem;max-width:580px;margin-bottom:0;">Comprehensive CBC Learning for Grades 10, 11, and 12.</p>
    <div class="pathways-grid">
      <div class="pathway-card">
        <div class="pathway-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
        </div>
        <h3>STEM Pathway</h3>
        <p>Pure Sciences, Applied Sciences, and Technical studies for future doctors, engineers, and tech innovators.</p>
        <ul class="pathway-subjects">
          <li>Mathematics &amp; Computer Science</li>
          <li>Physics, Chemistry &amp; Biology</li>
          <li>Agriculture &amp; Home Science</li>
        </ul>
      </div>
      <div class="pathway-card">
        <div class="pathway-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M3 12h18M3 18h12"/></svg>
        </div>
        <h3>Social Sciences</h3>
        <p>Humanities and Business studies for future leaders, legal minds, and entrepreneurs.</p>
        <ul class="pathway-subjects">
          <li>History &amp; Citizenry</li>
          <li>Geography &amp; Business Studies</li>
          <li>Religious Education (CRE)</li>
        </ul>
      </div>
      <div class="pathway-card">
        <div class="pathway-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        </div>
        <h3>Arts &amp; Sports</h3>
        <p>Physical excellence and creative expression through professional sports science and the arts.</p>
        <ul class="pathway-subjects">
          <li>Sports Science &amp; PE</li>
          <li>Performing Arts (Music/Drama)</li>
          <li>Fine Arts &amp; Design</li>
        </ul>
      </div>
    </div>
    <div class="cbc-advantage">
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;">
          <span style="background:var(--red);color:white;padding:4px 10px;border-radius:4px;font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;">CORE</span>
          <h3 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:var(--navy);margin:0;">Mandatory Subjects</h3>
        </div>
        <p style="font-size:0.93rem;color:var(--text-muted);margin-bottom:1.5rem;">All students undertake these foundational subjects regardless of chosen pathway:</p>
        <div class="competencies">
          <div class="competency"><div class="competency-dot"></div>English</div>
          <div class="competency"><div class="competency-dot"></div>Kiswahili</div>
          <div class="competency"><div class="competency-dot"></div>Mathematics</div>
          <div class="competency"><div class="competency-dot"></div>Physical Education</div>
          <div class="competency"><div class="competency-dot"></div>Life Skills</div>
          <div class="competency"><div class="competency-dot"></div>Community Service</div>
        </div>
      </div>
      <div>
        <h3 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:var(--navy);margin-bottom:1rem;">The CBC Approach</h3>
        <p style="font-size:0.93rem;color:var(--text-muted);margin-bottom:1rem;">At Kithumula, our teaching goes beyond the classroom. We focus on <strong>Community Service Learning (CSL)</strong>, where students apply their academic knowledge to solve real-world challenges within Matinyani Sub-County.</p>
        <p style="font-size:0.93rem;color:var(--text-muted);">This ensures our graduates are not only academically capable but also ethically fit and ready for social and economic development.</p>
      </div>
    </div>
  </div>
</section>

<!-- PORTALS SECTION -->
<section class="portals-section">
  <div class="container">
    <div class="section-tag">Quick Access</div>
    <h2 class="section-heading">School Portals</h2>
    <div class="portals-grid">
      <div class="portal-card portal-admin">
        <div class="portal-icon">🔐</div>
        <div class="portal-body">
          <h3>Admin Portal</h3>
          <p>School administration — manage staff, students, classes, announcements and enrolment enquiries.</p>
        </div>
        <a href="/admin/login" class="portal-btn">Sign In →</a>
      </div>
      <div class="portal-card portal-teacher">
        <div class="portal-icon">👩‍🏫</div>
        <div class="portal-body">
          <h3>Teacher Portal</h3>
          <p>Enter and manage student marks, view class results, and download report forms and performance summaries.</p>
        </div>
        <a href="/teacher/login" class="portal-btn">Sign In →</a>
      </div>
      <div class="portal-card portal-student">
        <div class="portal-icon">📋</div>
        <div class="portal-body">
          <h3>Student Results</h3>
          <p>Students, parents and guardians — view and download your academic report form using your admission number.</p>
        </div>
        <a href="#results-lookup" class="portal-btn">View Results →</a>
      </div>
    </div>
  </div>
</section>

<!-- STUDENT RESULTS LOOKUP -->
<section class="results-lookup-section" id="results-lookup">
  <div class="container">
    <div class="lookup-grid">
      <div>
        <div class="section-tag">Students · Parents · Guardians</div>
        <h2 class="section-heading">View Your Results</h2>
        <p style="color:var(--text-muted);font-size:1rem;margin-bottom:2rem;line-height:1.8;">Enter your <strong>Admission Number</strong> and <strong>one of your names</strong> to instantly view your academic report form online or download it as a PDF.</p>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <div style="width:36px;height:36px;background:rgba(255,255,255,0.12);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;">🔒</div>
            <div><strong style="font-size:0.88rem;color:rgba(255,255,255,0.9);">Private & secure</strong><br><span style="font-size:0.83rem;color:rgba(255,255,255,0.5);">Your name must match our records to access any results.</span></div>
          </div>
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <div style="width:36px;height:36px;background:rgba(255,255,255,0.12);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;">📥</div>
            <div><strong style="font-size:0.88rem;color:rgba(255,255,255,0.9);">Download PDF</strong><br><span style="font-size:0.83rem;color:rgba(255,255,255,0.5);">Get a printable CBC report form with all subjects, grades and class rank.</span></div>
          </div>
        </div>
      </div>
      <div class="lookup-form-card">
        <h3>Results Lookup</h3>
        <% if (flash.lookup_error && flash.lookup_error.length) { %>
          <div class="flash flash-error"><%= flash.lookup_error[0] %></div>
        <% } %>
        <form action="/results/lookup" method="POST">
          <div class="form-group">
            <label>Admission Number <span style="color:var(--red);">*</span></label>
            <input type="text" name="adm_number" required placeholder="e.g. KSS2026001" style="text-transform:uppercase;">
          </div>
          <div class="form-group">
            <label>Your First or Last Name <span style="color:var(--red);">*</span></label>
            <input type="text" name="name" required placeholder="e.g. Alice or Mutua">
          </div>
          <button type="submit" class="btn-submit">Find My Results →</button>
        </form>
        <p style="font-size:0.78rem;color:#94a3b8;margin-top:1rem;text-align:center;">Can't find your results? Contact your class teacher or the school office.</p>
      </div>
    </div>
  </div>
</section>

<!-- ENROLMENT FORM -->
<section class="enrol-section" id="enrol">
  <div class="container">
    <% if (flash.success && flash.success.length) { %>
      <div class="flash flash-success"><%= flash.success[0] %></div>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <div class="flash flash-error"><%= flash.error[0] %></div>
    <% } %>
    <div class="enrol-grid">
      <div>
        <div class="section-tag">Enrolment</div>
        <h2 class="section-heading">Join Us for 2026</h2>
        <p style="color:var(--text-muted);font-size:1rem;margin-bottom:2rem;">Enrolment is now open for Grade 10. Fill in the enquiry form and our team will be in touch within 2 working days.</p>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <div style="width:36px;height:36px;background:var(--light);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--navy-mid)" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div><strong style="font-size:0.88rem;color:var(--navy);">Location</strong><br><span style="font-size:0.85rem;color:var(--text-muted);">Matinyani, Kitui County, Kenya</span></div>
          </div>
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <div style="width:36px;height:36px;background:var(--light);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--navy-mid)" stroke-width="1.8" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div><strong style="font-size:0.88rem;color:var(--navy);">Email</strong><br><a href="mailto:info@kithumula.sc.ke" style="font-size:0.85rem;color:var(--red);">info@kithumula.sc.ke</a></div>
          </div>
        </div>
      </div>
      <div class="form-card">
        <h3>Enrolment Enquiry</h3>
        <p>All fields marked * are required.</p>
        <form action="/enquire" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label>Student Name *</label>
              <input type="text" name="student_name" required placeholder="Full name">
            </div>
            <div class="form-group">
              <label>Parent / Guardian *</label>
              <input type="text" name="parent_name" required placeholder="Full name">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Phone Number *</label>
              <input type="tel" name="phone" required placeholder="07XX XXX XXX">
            </div>
            <div class="form-group">
              <label>Grade Applying For *</label>
              <select name="grade" required>
                <option value="">Select grade</option>
                <option value="Grade 10">Grade 10</option>
                <option value="Grade 11">Grade 11</option>
                <option value="Grade 12">Grade 12</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email" placeholder="optional">
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="message" rows="3" placeholder="Any questions or notes?"></textarea>
          </div>
          <button type="submit" class="btn-submit">Submit Enquiry</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script>
// Nav dropdown toggle
document.querySelectorAll('.nav-dropdown-btn').forEach(btn => {
  btn.addEventListener('click', e => {
    e.stopPropagation();
    btn.closest('.nav-dropdown').classList.toggle('open');
  });
});
document.addEventListener('click', () => {
  document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
});

  { title:'Excellence in Education', subtitle:'Empowering the next generation in Matinyani through high-quality CBC learning.', cta:'Enrol for 2026', href:'#enrol' },
  { title:'A Future Full of Hope', subtitle:'Nurturing academically and ethically fit citizens for social and economic development.', cta:'View Pathways', href:'#pathways' },
  { title:'Built by the Community', subtitle:'Serving students from Kithumula, ACK Ngomango, Kaluni, Kitamwiki, Ndiuni and beyond.', cta:'Our Story', href:'#about' },
  { title:"Shaping Tomorrow's Leaders", subtitle:'Grade 10–12 CBC education that develops the whole student — academically and ethically.', cta:'Enrol for 2026', href:'#enrol' }
];
let current = 0, intervalId = null;
function showSlide(n) {
  document.querySelectorAll('.slide').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.dot').forEach(d => d.classList.remove('active'));
  document.querySelectorAll('.slide')[n].classList.add('active');
  document.querySelectorAll('.dot')[n].classList.add('active');
  const d = slideData[n];
  document.getElementById('slide-title').textContent = d.title;
  document.getElementById('slide-subtitle').textContent = d.subtitle;
  const cta = document.getElementById('slide-cta');
  cta.textContent = d.cta; cta.href = d.href;
  current = n;
}
function setSlide(n) { clearInterval(intervalId); showSlide(n); startAuto(); }
function startAuto() { intervalId = setInterval(() => showSlide((current+1)%4), 5000); }
document.addEventListener('DOMContentLoaded', () => { showSlide(0); startAuto(); });
</script>
</body>
</html>
