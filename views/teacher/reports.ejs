<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reports | KSS Teacher Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .term-selector { display:flex; align-items:center; gap:1rem; flex-wrap:wrap; background:var(--light); border-radius:8px; padding:1rem 1.25rem; margin-bottom:2rem; }
    .term-selector label { font-size:0.82rem; font-weight:600; color:var(--navy); }
    .term-selector select { padding:0.45rem 0.85rem; border:1px solid var(--border); border-radius:6px; font-family:inherit; font-size:0.88rem; background:white; }
    .report-cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.25rem; }
    .rcard { background:white; border:1px solid var(--border); border-radius:12px; overflow:hidden; }
    .rcard-header { background:var(--navy); padding:1.1rem 1.25rem; display:flex; align-items:center; gap:12px; }
    .rcard-badge { width:44px; height:44px; border-radius:8px; background:rgba(255,255,255,0.12); display:flex; align-items:center; justify-content:center; font-family:'DM Serif Display',serif; font-size:0.88rem; color:white; font-weight:600; flex-shrink:0; text-align:center; line-height:1.2; }
    .rcard-title { color:white; font-weight:600; font-size:0.95rem; }
    .rcard-sub { color:rgba(255,255,255,0.5); font-size:0.75rem; margin-top:2px; }
    .rcard-body { padding:1.1rem 1.25rem; display:flex; flex-direction:column; gap:0.6rem; }
    .rcard-view-btn { display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1rem; border-radius:8px; border:1.5px solid var(--border); background:white; font-size:0.85rem; font-weight:600; color:var(--navy); text-decoration:none; transition:all 0.15s; }
    .rcard-view-btn:hover { border-color:var(--navy); background:var(--light); }
    .rcard-view-btn.primary { background:var(--navy); border-color:var(--navy); color:white; }
    .rcard-view-btn.primary:hover { background:var(--navy-mid); }
    .rcard-view-btn.gold { background:var(--gold); border-color:var(--gold); color:var(--navy); }
    .rcard-view-btn .lbl { display:flex; flex-direction:column; line-height:1.3; }
    .rcard-view-btn .lbl small { font-weight:400; font-size:0.72rem; opacity:0.7; }
    .rcard-view-btn .icon { font-size:1.1rem; }
    .rcard-divider { font-size:0.65rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--text-muted); padding-top:0.25rem; }
    .no-classes { text-align:center; padding:4rem 2rem; }
    .grade-key-strip { background:var(--off-white); border:1px solid var(--border); border-radius:10px; padding:1.25rem; margin-top:2rem; }
    .grade-key-strip h3 { font-size:0.82rem; font-weight:600; color:var(--navy); margin-bottom:0.75rem; }
    .grade-key-items { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:0.5rem; }
    .gki { display:flex; align-items:center; gap:8px; font-size:0.82rem; color:var(--text-muted); }
    .gki-badge { width:28px; height:20px; border-radius:3px; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:700; flex-shrink:0; }
    @media(max-width:480px){
      .term-selector { flex-direction:column; align-items:flex-start; gap:0.75rem; }
      .rcard-view-btn { padding:0.65rem 0.85rem; font-size:0.82rem; }
    }
  </style>
</head>
<body class="admin-body">
<%- include('nav', { activePage: 'reports', myClass }) %>
<div class="admin-layout">
  <div class="admin-page-header">
    <h1>Reports &amp; PDFs</h1>
    <p>View and download student report forms and class performance summaries.</p>
  </div>
  <% if (flash.success && flash.success.length) { %><div class="flash flash-success"><%= flash.success[0] %></div><% } %>

  <div class="term-selector">
    <div style="display:flex;align-items:center;gap:0.6rem;">
      <label>Term:</label>
      <select id="termSelect">
        <option value="Term+1">Term 1</option>
        <option value="Term+2">Term 2</option>
        <option value="Term+3">Term 3</option>
      </select>
    </div>
    <div style="display:flex;align-items:center;gap:0.6rem;">
      <label>Year:</label>
      <select id="yearSelect">
        <% years.forEach(y => { %><option value="<%= y %>"><%= y %></option><% }) %>
      </select>
    </div>
    <span style="font-size:0.78rem;color:var(--text-muted);">Links update automatically</span>
  </div>

  <% if (!classes.length) { %>
  <div class="no-classes">
    <div style="font-size:3rem;margin-bottom:1rem;">📋</div>
    <p style="font-size:1rem;font-weight:600;color:var(--navy);margin-bottom:0.5rem;">No classes assigned yet</p>
    <p style="color:var(--text-muted);">Ask the admin to assign subjects to your account.</p>
  </div>
  <% } else { %>

  <div class="report-cards-grid">
    <% classes.forEach(cls => { %>
    <div class="rcard">
      <div class="rcard-header">
        <div class="rcard-badge"><%= cls.name.replace('Grade ','G') %></div>
        <div>
          <div class="rcard-title"><%= cls.name %></div>
          <div class="rcard-sub"><%= cls.student_count %> students · <%= cls.marks_count %> marks entered</div>
        </div>
      </div>
      <div class="rcard-body">
        <a href="/teacher/results/<%= cls.id %>" class="rcard-view-btn">
          <div class="lbl"><span>📊 View Results Online</span><small>Ranked table with subject breakdown</small></div>
          <span class="icon">→</span>
        </a>
        <div class="rcard-divider">Report Forms</div>
        <a href="#" class="rcard-view-btn pdf-view-btn" data-base="/teacher/pdf/view/reports/<%= cls.id %>">
          <div class="lbl"><span>👁 View Report Forms</span><small>Open in browser</small></div>
          <span class="icon">📄</span>
        </a>
        <a href="#" class="rcard-view-btn primary pdf-dl-btn" data-base="/teacher/pdf/reports/<%= cls.id %>">
          <div class="lbl"><span>📥 Download Report Forms</span><small>All students · sorted by rank</small></div>
          <span class="icon">↓</span>
        </a>
        <div class="rcard-divider">Class Summary</div>
        <a href="#" class="rcard-view-btn pdf-view-btn" data-base="/teacher/pdf/view/summary/<%= cls.id %>">
          <div class="lbl"><span>👁 View Summary</span><small>Open in browser</small></div>
          <span class="icon">📊</span>
        </a>
        <a href="#" class="rcard-view-btn gold pdf-dl-btn" data-base="/teacher/pdf/summary/<%= cls.id %>">
          <div class="lbl"><span>📥 Download Summary</span><small>Landscape · all students</small></div>
          <span class="icon">↓</span>
        </a>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="grade-key-strip">
    <h3>📌 CBC Grading Scale</h3>
    <div class="grade-key-items">
      <div class="gki"><div class="gki-badge" style="background:#d1fae5;color:#065f46;">EE</div><span>Exceeds Expectation (80–100%)</span></div>
      <div class="gki"><div class="gki-badge" style="background:#dbeafe;color:#1e40af;">ME</div><span>Meets Expectation (65–79%)</span></div>
      <div class="gki"><div class="gki-badge" style="background:#fef9c3;color:#92400e;">AE</div><span>Approaches Expectation (50–64%)</span></div>
      <div class="gki"><div class="gki-badge" style="background:#fee2e2;color:#991b1b;">BE</div><span>Below Expectation (&lt;50%)</span></div>
    </div>
  </div>
  <% } %>
</div>

<!-- PDF Viewer Modal -->
<div id="pdfModal" style="display:none;position:fixed;inset:0;background:rgba(10,20,40,0.8);z-index:9999;padding:0.75rem;overflow:auto;">
  <div style="background:white;border-radius:10px;max-width:900px;margin:0 auto;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.4);">
    <div style="background:var(--navy);padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;">
      <span id="modalTitle" style="font-size:0.88rem;font-weight:600;color:white;"></span>
      <div style="display:flex;align-items:center;gap:1rem;">
        <a id="modalDl" href="#" style="font-size:0.78rem;color:rgba(255,255,255,0.65);text-decoration:underline;">📥 Download</a>
        <button onclick="closePdfModal()" style="background:rgba(255,255,255,0.15);border:none;color:white;width:30px;height:30px;border-radius:50%;font-size:1rem;cursor:pointer;">✕</button>
      </div>
    </div>
    <iframe id="pdfFrame" src="" style="width:100%;height:75vh;border:none;background:#525659;"></iframe>
  </div>
</div>

<script>
function getParams(){
  return '?term='+document.getElementById('termSelect').value+'&year='+document.getElementById('yearSelect').value;
}
function updateLinks(){
  const p=getParams();
  document.querySelectorAll('.pdf-view-btn').forEach(el=>{ el.dataset.url=el.dataset.base+p; el.href='#'; });
  document.querySelectorAll('.pdf-dl-btn').forEach(el=>{ el.href=el.dataset.base+p; });
}
['termSelect','yearSelect'].forEach(id=>document.getElementById(id).addEventListener('change',updateLinks));

document.querySelectorAll('.pdf-view-btn').forEach(btn=>{
  btn.addEventListener('click',function(e){
    e.preventDefault();
    const url=this.dataset.url||this.dataset.base+getParams();
    const label=this.querySelector('.lbl span').textContent;
    openPdfModal(url,label,this.dataset.base+getParams());
  });
});

function openPdfModal(url,title,dlUrl){
  document.getElementById('modalTitle').textContent=title;
  document.getElementById('modalDl').href=dlUrl||url;
  document.getElementById('pdfFrame').src=url;
  document.getElementById('pdfModal').style.display='block';
  document.body.style.overflow='hidden';
}
function closePdfModal(){
  document.getElementById('pdfModal').style.display='none';
  document.getElementById('pdfFrame').src='';
  document.body.style.overflow='';
}
document.getElementById('pdfModal').addEventListener('click',function(e){if(e.target===this)closePdfModal();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')closePdfModal();});
updateLinks();
</script>
<%- include('../partials/portal-footer') %>
</body></html>
